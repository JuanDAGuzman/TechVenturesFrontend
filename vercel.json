{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "techventuresco.vercel.app"
        }
      ],
      "destination": "https://techventuresco.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/catalogo",
      "destination": "/catalogo.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|png|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}